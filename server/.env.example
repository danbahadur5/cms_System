PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/course_management

# Admin login (server-side only — never prefix with VITE_)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
JWT_SECRET=use-a-long-random-string-for-jwt-signing

# Cloudinary (https://cloudinary.com/console) — optional; if omitted, images save under server/uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=course-management

# If the SPA is on a different host than this API, set the public API base so /uploads URLs work (local dev: leave empty)
# API_PUBLIC_URL=https://your-api.example.com
